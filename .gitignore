# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
# pnpm local content-addressable store — generated by pnpm install, holds
# ~20k+ package blobs. Never commit. Lives at repo root when pnpm is configured
# with a local store-dir (which this project does).
.pnpm-store/
# Local Claude Code skills + sandbox config — per-developer tooling state,
# not project source.
.claude/
# All build output lives here — generated, never committed. Includes:
#   releases/web/      built React SPA
#   releases/mac/      Node server bundle for macOS
#   releases/mac-dmg/  signed + notarized DMGs (shippable)
#   releases/mac-pkg/  legacy .pkg installer
#   releases/win/      Node server bundle for Windows
#   releases/win-pkg/  Inno Setup installer (nebulis-setup.exe)
releases/
dist-ssr
# NSSM binary — downloaded by scripts/download-nssm.mjs or CI
installers/windows/installer/nssm.exe
installers/windows/installer/caddy.exe
*.local
/data/

# Secrets — never commit credentials or private keys
.env*
*.pem
*.key

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
test-results/*
trace/*
playwright-report/
coverage/
server/dist/
build/Release/
*.node
.pkg-cache/

church-*.md
audit-*.md

# Church purist audit reports (local-only)
church-audit/

# .NET / C# build outputs (Windows tray app at installers/windows/tray/)
# bin/ holds compiled DLLs and the published Nebulis.Tray.exe; obj/ holds
# intermediate build artifacts and NuGet restore cache. Both are regenerated
# by `dotnet publish` and must not be tracked.
installers/windows/tray/bin/
installers/windows/tray/obj/
# Defensive: catch any other .NET project bin/obj that gets added later.
**/bin/Debug/
**/bin/Release/
**/bin/publish/
**/obj/Debug/
**/obj/Release/
# Visual Studio / Rider local files
*.user
*.suo
*.lscache
.vs/
.idea/
# .NET coverage and test results
TestResults/
.env

# Vitest temp DATA_DIRs. Some backend tests need a DATA_DIR outside os.tmpdir()
# (import.ts's defense-in-depth check refuses upload tempPaths outside
# os.tmpdir(), so the destination library dir must live elsewhere). They now
# mkdtemp under .test-tmp/, which tests/globalSetup.ts wipes before each run.
.test-tmp/
# Isolated test database — DATA_DIR for the Vitest worker (never the dev DB).
.test-data/
# Legacy: older runs wrote these directly to the repo root. Kept ignored so any
# stragglers from before the .test-tmp/ change don't show up in git.
nebulis-*-test-*/
